{
  "name": "swipestats",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "velite build && next build && bun db:migrate",
    "postinstall": "velite build",
    "check": "bun db:check && velite build && eslint . && tsc --noEmit && bun test",
    "clean": "rm -rf node_modules .next .turbo .cache .velite .eslintcache bun.lock",
    "reinstall": "bun run clean && bun install",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check --dialect=postgresql --out=drizzle",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:catalog": "bun src/scripts/seed-dating-services.ts",
    "db:seed:catalog:preview": "bun src/scripts/seed-dating-services.ts --include-preview-fixtures",
    "dev": "portless",
    "dev:direct": "node scripts/sync-localcan-target.mjs && next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx,json}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx,json}\" --cache",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "ls:overview": "bun run src/scripts/lemonsqueezy/overview.ts",
    "preview": "next build && next start",
    "start": "next start",
    "test": "bun test",
    "typecheck": "velite build && tsc --noEmit",
    "velite:build": "velite build",
    "velite:dev": "velite --watch",
    "email:dev": "email dev",
    "amplitude:sync-taxonomy": "bun src/scripts/sync-amplitude-taxonomy.ts"
  },
  "portless": {
    "name": "swipestats",
    "script": "dev:direct"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.2",
    "@amplitude/analytics-node": "^1.5.60",
