# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.ts"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/swipestats"

# Billing (LemonSqueezy)
LEMON_SQUEEZY_API_KEY=""
LEMON_SQUEEZY_WEBHOOK_SECRET=""

# Email (optional)
RESEND_API_KEY=""

# Blob Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=""

# AI Services
ANTHROPIC_API_KEY=""
FAL_KEY=""

# Analytics (PostHog) - optional for development
# PostHog hosts are hardcoded: /ingest (client) and https://eu.i.posthog.com (server)
NEXT_PUBLIC_POSTHOG_KEY=""

# Analytics (Amplitude) - optional. Publishable browser key, EU server zone.
# Unset => the Amplitude provider no-ops. Use the dev/staging project key
# locally; set a separate prod project key in the production environment.
NEXT_PUBLIC_AMPLITUDE_API_KEY=""

# Slack (required webhook values omitted here; obtain them from Slack settings)
# Optional member ID for the Codex cloud-task app, for example U0123456789.
# Configure only in production after adding @Codex to #bot-messages.
SLACK_CODEX_USER_ID=""

# Client-side (NEXT_PUBLIC_*)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_MAPBOX_PUBLIC_API_KEY=""
NEXT_PUBLIC_VERCEL_ENV="development"
